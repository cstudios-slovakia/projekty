#!/usr/bin/expect -f
set timeout 30
set password "b115cadfc1"
set user "uid1102122"
set host "shell.r5.websupport.sk"
set port "27127"
set dest_dir "cstudios.sk/sub/projektyerik"

spawn ssh -p $port -o StrictHostKeyChecking=no $user@$host "cd $dest_dir && ls -la"

expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    eof
}
