# 1. Create .env manually with harvested credentials
send "cat << 'EOF' > .env\n"
send "APP_INSTALLED=true\n"
send "DB_DRIVER=pgsql\n"
send "DB_HOST=db.r5.websupport.sk\n"
send "DB_PORT=5432\n"
send "DB_NAME=16AYwX6g\n"
send "DB_USER=EHL9hL8w\n"
send "DB_PASS=g&S/vp:E5;393L?h%W($\n"
send "INSTALLED_AT=[clock format [clock seconds] -format {%Y-%m-%d %H:%M:%S}]\n"
