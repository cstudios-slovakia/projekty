expect "$ "

# 2. Upload the Skeleton composer.json
send "cat << 'EOF' > composer.json\n"
send [exec cat composer.instance.json]
send "\nEOF\r"
expect "$ "

# 3. Upload the Proxy index.php
send "cat << 'EOF' > index.php\n"
send [exec cat index.php]
send "\nEOF\r"
expect "$ "

# 4. Clean up existing files to avoid conflicts with proxy
send "rm -f index.html favicon.png vite.svg\n"
send "rm -rf assets api\n"
expect "$ "

# 5. Run Composer Update (This pulls the core into vendor/ and runs migration)
send "composer update --no-interaction\r"
