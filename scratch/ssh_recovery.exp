        send "cd $dest_dir\r"
    }
}

expect -re {.*[\$#] }
send "echo '{\"require\":{\"cstudios-slovakia/projekty\":\"dev-v1.7.0-new#28f2c0b\"\}\}' > composer.json\r"

expect -re {.*[\$#] }
send "composer install --no-interaction\r"

expect -re {.*[\$#] }
send "echo 'APP_INSTALLED=true' > .env\r"

expect -re {.*[\$#] }
send "cat << 'EOF' > api/config.php
<?php
define('DB_HOST', 'db.r5.websupport.sk');
define('DB_NAME', '16AYwX6g_composerUpdateTest');
define('DB_USER', 'kFT04vWO');
define('DB_PASS', '&SF2\[vL+SF1(Jb7UAPK*');
