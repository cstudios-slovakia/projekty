{
    "name": "cstudios-slovakia/projekty",
    "description": "A premium project lead tracker with Multi-DB support.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Erik",
            "email": "erik@cstudios.design"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "scripts": {
        "post-create-project-cmd": [
            "php -r \"if(!file_exists('api/config.php')) copy('api/config.php.example', 'api/config.php');\" || true"
        ],
        "post-install-cmd": [
            "php publish.php",
            "php api/migrate.php"
        ],
        "post-update-cmd": [
            "php publish.php",
            "php api/migrate.php"
        ]
    }
}
