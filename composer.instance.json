{
    "name": "cstudios-slovakia/projekty-instance",
    "description": "A premium project lead tracker with Multi-DB support.",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-json": "*",
        "cstudios-slovakia/projekty": "v1.7.8"
    },
    "scripts": {
        "post-create-project-cmd": [
            "php -r \"copy('api/config.php.example', 'api/config.php');\" || true"
        ],
        "post-install-cmd": [
            "php vendor/cstudios-slovakia/projekty/api/migrate.php"
        ],
        "post-update-cmd": [
            "php vendor/cstudios-slovakia/projekty/api/migrate.php"
        ]
    }
}
